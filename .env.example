# Copy to .env and fill in. The .env file is gitignored.
# All variables are OPTIONAL — the forecasting core and RAG retrieval run without any of them.

# ---------------------------------------------------------------------------
# Claude / Anthropic (enables AI insights, the chat assistant, and LLM tuning)
# Without this key, AI features degrade gracefully and everything else still works.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Model id and reasoning effort for the AI layer.
LSTM_FORECAST_AI__MODEL=claude-opus-4-8
LSTM_FORECAST_AI__EFFORT=high

# ---------------------------------------------------------------------------
# Runtime / paths
# ---------------------------------------------------------------------------
# Where data downloads and artifacts (vector indices, trained models) are cached.
LSTM_FORECAST_CACHE_DIR=.cache
# torch device: "auto" | "cpu" | "cuda" | "mps"
LSTM_FORECAST_DEVICE=auto
# Global random seed for reproducibility.
LSTM_FORECAST_SEED=20

# ---------------------------------------------------------------------------
# API service
# ---------------------------------------------------------------------------
LSTM_FORECAST_API__HOST=0.0.0.0
LSTM_FORECAST_API__PORT=8000
# Comma-separated CORS origins, or "*" for all.
LSTM_FORECAST_API__CORS_ORIGINS=*
